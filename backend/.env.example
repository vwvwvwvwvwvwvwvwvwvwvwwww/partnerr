NODE_ENV=development
# По умолчанию 4010 — порт 4000 часто занят другими приложениями
PORT=4010
# Публичный URL сайта (в production = https://ваш-домен.ru без слэша в конце)
APP_ORIGIN=http://127.0.0.1:8848
# Путь к результату `npm run build` во frontend (index.html внутри). Пусто = ../frontend/dist от каталога backend при NODE_ENV=production
FRONTEND_DIST=

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=agro_erp
DB_USER=agro_erp_user
DB_PASSWORD=change_me_securely
DB_POOL_MAX=10

JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_MINUTES=15
CSRF_COOKIE_NAME=csrf_token
SESSION_COOKIE_NAME=session_token

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_super_secure
ADMIN_FULL_NAME=Системный администратор
