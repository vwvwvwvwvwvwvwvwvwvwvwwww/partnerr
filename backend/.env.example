NODE_ENV=development
PORT=4010
APP_ORIGIN=http://127.0.0.1:8848
FRONTEND_DIST=

# SQLite — без отдельного сервера БД (удобно для хостинга)
DB_DRIVER=sqlite
SQLITE_PATH=./data/agro_erp.sqlite

# PostgreSQL (если нужен PostGIS локально): DB_DRIVER=postgres и параметры ниже
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=agro_erp
# DB_USER=agro_erp_user
# DB_PASSWORD=change_me_securely
# DB_POOL_MAX=10

JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_MINUTES=15
CSRF_COOKIE_NAME=csrf_token
SESSION_COOKIE_NAME=session_token

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_super_secure
ADMIN_FULL_NAME=Системный администратор

# Почта — уведомления водителю при сохранении путевого листа (DOCX во вложении)
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your_login@mail.ru
# SMTP_PASS=app_password
# SMTP_FROM=Партнер <your_login@mail.ru>

# Доп. получатели каждого путевого листа (через запятую), помимо e-mail в форме
# WAYBILL_NOTIFY_EMAILS=agronom@example.com, buhgalter@example.com
