{
  "name": "agro-erp",
  "private": true,
  "description": "Корневые скрипты: backend и frontend в отдельных папках",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "setup": "npm install && npm run install:all",
    "bootstrap": "node scripts/bootstrap.mjs",
    "bootstrap:nodocker": "SKIP_DOCKER=1 npm run bootstrap",
    "install:all": "npm install --prefix backend && npm install --include=dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "start:prod": "NODE_ENV=production npm run start --prefix backend",
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:docker": "node scripts/predocker.mjs && npm run dev",
    "dev:nodocker": "npm run dev",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "migrate": "npm run migrate --prefix backend",
    "create-admin": "npm run create-admin --prefix backend",
    "seed-staff": "npm run seed-staff --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
